# Przykład upstreamu API (lokalny dev) — produkcja: patrz nginx-devcord.ndevelopment.org.conf
#
# Głos: LiveKit (VoiceKit) na osobnym porcie — np. wss :7880 → 127.0.0.1:7880 (patrz blok server w nginx-devcord.ndevelopment.org.conf).
# Mesh / disc-signaling nie są już używane.

upstream devcord_api {
    server 127.0.0.1:12823;
}

server {
    listen 80;
    server_name devcord.ndevelopment.org;

    # /api/ping — publiczny ping (JSON); opcjonalnie osobno krótszy timeout
    location = /api/ping {
        proxy_pass http://devcord_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 15s;
    }

    location /api/ {
        proxy_pass http://devcord_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
