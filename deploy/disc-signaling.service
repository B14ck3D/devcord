# Build: go build -C /root/disc/backend -o bin/signaling ./cmd/signaling
[Unit]
Description=Disc signaling and chat WebSocket (Ndevelopment)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/disc/backend
Environment=LISTEN_ADDR=0.0.0.0:23623
ExecStart=/root/disc/backend/bin/signaling
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
