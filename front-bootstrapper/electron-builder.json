{
  "appId": "org.devcord.bootstrapper",
  "productName": "Devcord Installer",
  "asar": false,
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "build/icons/icon.ico",
      "to": "icon.ico"
    }
  ],
  "extraMetadata": {
    "main": "dist-electron/main.js"
  },
  "win": {
    "icon": "build/icons/icon.ico",
    "requestedExecutionLevel": "asInvoker",
    "target": [
      {
        "target": "portable",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "Devcord_Installer.${ext}"
  },
  "portable": {
    "unpackDirName": "devcord-setup-cache",
    "splashImage": "build/splash.bmp"
  }
}
